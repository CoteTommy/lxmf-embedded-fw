LXMF_NODE_MODE_TCP_CLIENT=1
LXMF_CAPTURE_PROFILE=high

# Optional network override values. Leave these unset after the device has been
# provisioned over BLE and stored its config persistently.
# LXMF_WIFI_SSID=your-ssid
# LXMF_WIFI_PASSWORD=your-password
# LXMF_TCP_HOST=192.168.1.2
# LXMF_TCP_PORT=7443
